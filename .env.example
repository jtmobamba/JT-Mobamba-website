# =============================================================================
# JT MOBAMBA ELECTRONICS - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# DATABASE - MONGODB
# =============================================================================
# MongoDB Atlas Connection String
# Sign up at: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/jtmobamba?retryWrites=true&w=majority

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT Secret Key (generate a strong random string)
# You can generate one at: https://randomkeygen.com/
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Expiration
JWT_EXPIRES_IN=7d

# Session Secret
SESSION_SECRET=your-session-secret-key-change-this

# =============================================================================
# EMAIL - RESEND API
# =============================================================================
# Sign up at: https://resend.com
# Domain: jtmobamba.com (must be verified)

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration
EMAIL_FROM=newsletter@jtmobamba.com
EMAIL_FROM_NAME=JT Mobamba Electronics

# =============================================================================
# GODADDY HOSTING (if using GoDaddy VPS)
# =============================================================================
# Domain
DOMAIN=jtmobamba.com

# SSL (Let's Encrypt or GoDaddy SSL)
SSL_ENABLED=true

# =============================================================================
# OPTIONAL - PAYMENT INTEGRATION
# =============================================================================
# Stripe (if using Stripe for payments)
# STRIPE_PUBLIC_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx

# Shopify (if using Shopify checkout)
# SHOPIFY_DOMAIN=your-store.myshopify.com
# SHOPIFY_STOREFRONT_TOKEN=xxxxx
